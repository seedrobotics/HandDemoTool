<robot name="rh8d">
  <material name="profile">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>
  <material name="plate">
    <color rgba="1.0 1.0 1.0 1.0"/>
  </material>
  <material name="grey">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>
  <material name="silver">
    <color rgba="0.8 0.8 0.8 1.0"/>
  </material>
  <material name="rh8d_color">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>
  <material name="white">
    <color rgba="1.0 1.0 1.0 1.0"/>
  </material>
  <material name="black">
    <color rgba="0.0 0.0 0.0 1.0"/>
  </material>
  <!-- https://gist.github.com/naoki-mizuno/5e63a13597d5c5fe817c1600b829595e -->
  <material name="coolgreen">
    <color rgba="0.1 0.3215686274509804 0.2215686274509803 1.0"/>
  </material>
  <material name="bloodorange">
    <color rgba="0.996078431372549 0.29411764705882354 0.011764705882352941 1.0"/>
  </material>
  <material name="bloodred">
    <color rgba="0.596078431372549 0.0 0.00784313725490196 1.0"/>
  </material>
  <!-- default joint export prefixes -->
  <!-- default link prefixes -->
  <gazebo>
    <plugin filename="libgazebo_ros_control.so" name="gazebo_ros_control">
      <robotNamespace>left/rh8d</robotNamespace>
      <robotSimType>gazebo_ros_control/DefaultRobotHWSim</robotSimType>
    </plugin>
  </gazebo>
  <!-- ++++++++++++++++++++++++++ robot +++++++++++++++++++++++++++++ -->
  <!-- World, center of global coordinate system-->
  <link name="world"/>
  <gazebo reference="world"/>
  <joint name="joint_base" type="revolute">
    <limit effort="0.5" lower="-1.57079632679" upper="1.57079632679" velocity="1.0"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <axis xyz="0 0 1"/>
    <parent link="world"/>
    <child link="l_forearm"/>
  </joint>
  <!-- NICOL fixed joint -->
      <sensor>l_Ibumper_sensor</sensor>
      <sensor>l_Rbumper_sensor</sensor>
      <sensor>l_Lbumper_sensor</sensor>
      <optoforce_topic>/left/optoforce_0</optoforce_topic>
      <optoforce_sensor>l_Mbumper_sensor</optoforce_sensor>
  <!-- disable lumping: fixed joint is replaced by revolute joint with zero limits -->
  <!-- RH8D gazebo laser plugin -->
  <gazebo reference="l_laser">
    <sensor name="l_laser_laser_distance_sensor" type="ray">
      <pose>0 0 0 0 0 0</pose>
      <visualize>False</visualize>
      <update_rate>50</update_rate>
      <ray>
        <scan>
          <horizontal>
            <!-- f sample -->
            <samples>25</samples>
            <!-- num rays-->
            <resolution>0.05</resolution>
            <!-- angular range -->
            <min_angle>0</min_angle>
            <max_angle>0</max_angle>
          </horizontal>
        </scan>
        <range>
          <!-- distance -->
          <min>0.003</min>
          <max>0.254</max>
          <resolution>0.001</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <!-- Noise parameters based on published spec for Hokuyo laser
              achieving "+-30mm" accuracy at range < 10m.  A mean of 0.0m and
              stddev of 0.01m will put 99.7% of samples within 0.03m of the true
              reading. -->
          <mean>0.0</mean>
          <stddev>0.0</stddev>
        </noise>
      </ray>
      <plugin filename="libNicolLaserPlugin.so" name="l_laser_laser_controller">
        <topicName>/left/laser</topicName>
        <frameName>l_laser</frameName>
      </plugin>
    </sensor>
  </gazebo>
  <!-- gazebo tip sensor plugin -->
  <gazebo>
    <plugin filename="libNicolF3DPlugin.so" name="l_f3d_sensor_plugin">
      <topic>/left/AllSensors</topic>
      <!-- links in the order of appearance in msg (index 0 to 3) -->
      <sensor>l_Tbumper_sensor</sensor>
      <sensor>l_Ibumper_sensor</sensor>
      <sensor>l_Rbumper_sensor</sensor>
      <sensor>l_Lbumper_sensor</sensor>
      <optoforce_topic>/left/optoforce_0</optoforce_topic>
      <optoforce_sensor>l_Mbumper_sensor</optoforce_sensor>
    </plugin>
  </gazebo>
